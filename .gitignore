/target
**/*.rs.bk
.DS_Store
# Claude Code session state (worktrees, settings) — local tooling, not code.
/.claude/
# .graph/ carries repo config, plans, and tools for CI; everything else
# under it (embedded DB state, scratch) stays ignored.
/.graph/*
!/.graph/config.toml
!/.graph/plans/
!/.graph/tools/
*.db
mise.local.toml
